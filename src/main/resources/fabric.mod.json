{
  "schemaVersion": 1,
  "id": "acaudit",
  "version": "${version}",
  "name": "ACAudit",
  "description": "Meteor Client addon for auditing anti-cheat systems.",
  "authors": ["broshan"],
  "contact": {},
  "icon": "assets/acaudit/icon.png",
  "environment": "client",
  "entrypoints": {
    "meteor": [
      "com.example.addon.AddonTemplate"
    ]
  },
  "mixins": [
    "acaudit.mixins.json"
  ],
  "custom": {
    "meteor-client:color": "225,25,25",
    "modmenu": {
      "parent": {
        "id": "meteor-client"
      }
    }
  },
  "depends": {
    "java": ">=${jdk_version}",
    "minecraft": "${minecraft_version}",
    "meteor-client": "*"
  }
}
